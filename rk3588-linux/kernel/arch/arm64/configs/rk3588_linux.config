# CONFIG_BCMDHD_SDIO=y is not set
CONFIG_BCMDHD_PCIE=y
CONFIG_MALI_CSF_SUPPORT=y
# Sensor framework used by the vendor ICM20600 / STK3311A drivers.
CONFIG_SENSOR_DEVICE=y
CONFIG_GSENSOR_DEVICE=y
CONFIG_GYROSCOPE_DEVICE=y
CONFIG_LIGHT_DEVICE=y
CONFIG_PROXIMITY_DEVICE=y
# ICM20600 accel + gyro on the current board revision.
CONFIG_ICM2060X_ACC=y
CONFIG_GYRO_ICM2060X=y
# BMI270 is disabled on this revision because I2C4 carries the active IMU.
# CONFIG_BMI270 is not set
# CONFIG_BMI270_I2C is not set
CONFIG_HCSR04_IIO=y
CONFIG_KC38_GPIO=y
